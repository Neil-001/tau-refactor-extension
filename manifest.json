{
  "name": "TAU Refactor",
  "description": "A Chrome Extension for TAU Refactor, a new home for past histograms!",
  "version": "0.1.4",
  "manifest_version": 3,
  "icons": {
    "16": "icon/icon-16.png",
    "32": "icon/icon-32.png",
    "48": "icon/icon-48.png",
    "128": "icon/icon-128.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://ims.tau.ac.il/TalSSO/*",
    "https://my.tau.ac.il/TAU_Student/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://ims.tau.ac.il/TalSSO/*"],
      "js": ["dist/ims.js"],
      "all_frames": true,
      "run_at": "document_end"
    },
    {
      "matches": ["https://my.tau.ac.il/TAU_Student/CourseGrades*"],
      "js": ["dist/mytau.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://ims.tau.ac.il/TalSSO/*",
      "https://my.tau.ac.il/TAU_Student/*"
    ]
  },
  "permissions": ["storage", "unlimitedStorage"]
}
